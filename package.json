{
  "name": "rocket-launchpad-bsc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "backend": "node server/apple-backend.mjs",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "hardhat:compile": "node scripts/compile-contracts.cjs",
    "deploy:factory:bsc": "npm run hardhat:compile && hardhat run scripts/deploy-factory.cjs --network bsc --no-compile",
    "deploy:factory:testnet": "npm run hardhat:compile && hardhat run scripts/deploy-factory.cjs --network bscTestnet --no-compile",
    "verify:factory:bsc": "hardhat verify --network bsc",
    "verify:factory:testnet": "hardhat verify --network bscTestnet",
    "verify:project:bsc": "node scripts/verify-project.cjs",
    "contracts:verify:project": "npm run verify:project:bsc",
    "deploy:cloudflare": "npm run build && npx wrangler pages deploy dist --project-name rocket-launchpad"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^16.6.1",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.6",
    "solc": "^0.8.28",
    "vite": "^5.4.11"
  }
}
